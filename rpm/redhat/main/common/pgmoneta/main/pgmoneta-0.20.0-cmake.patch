From 48c3100669025c0a06b89fc2f5485b92b956245e Mon Sep 17 00:00:00 2001
From: jesperpedersen <jesperpedersen.db@gmail.com>
Date: Mon, 19 Jan 2026 14:54:25 -0500
Subject: [PATCH] [#869] pgmoneta_consume_data_row_messages: Uninitialized
 variables

---
 src/CMakeLists.txt        | 4 ++++
 src/libpgmoneta/message.c | 5 +++--
 2 files changed, 7 insertions(+), 2 deletions(-)

diff --git a/src/CMakeLists.txt b/src/CMakeLists.txt
index d0539708..1323f90b 100644
--- a/src/CMakeLists.txt
+++ b/src/CMakeLists.txt
@@ -176,6 +176,10 @@ add_compile_options(-Wno-deprecated-declarations)
 add_compile_options(-Wunused)
 add_compile_options(-Wunused-result)
 add_compile_options(-Wsign-compare)
+check_c_compiler_flag(-Wuninitialized HAS_WUNINITIALIZED)
+if (HAS_WUNINITIALIZED)
+  add_compile_options(-Wuninitialized)
+endif()
 
 #
 # version number and string management
diff --git a/src/libpgmoneta/message.c b/src/libpgmoneta/message.c
index 8d3c74f9..e42574f0 100644
--- a/src/libpgmoneta/message.c
+++ b/src/libpgmoneta/message.c
@@ -32,6 +32,7 @@
 #include <extension.h>
 #include <logging.h>
 #include <manifest.h>
+#include <message.h>
 #include <network.h>
 #include <security.h>
 #include <server.h>
@@ -2182,8 +2183,8 @@ pgmoneta_consume_copy_stream_end(struct stream_buffer* buffer, struct message* m
 int
 pgmoneta_consume_data_row_messages(int srv, SSL* ssl, int socket, struct stream_buffer* buffer, struct query_response** response)
 {
-   int cols;
-   int status;
+   int cols = 0;
+   int status = MESSAGE_STATUS_ERROR;
    char* name = NULL;
    struct message* msg = (struct message*)malloc(sizeof(struct message));
    struct tuple* current = NULL;
