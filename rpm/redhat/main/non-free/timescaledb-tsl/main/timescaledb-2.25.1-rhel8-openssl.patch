From 31f70b7a394d5a9bfbf2efbe7fef3258e5d4cefc Mon Sep 17 00:00:00 2001
From: Arthur Nascimento <arthur.nascimento@enterprisedb.com>
Date: Wed, 18 Feb 2026 19:32:16 -0300
Subject: [PATCH] Guard old openssl API functions

The openssl functions SSL_library_init(), SSL_load_error_strings(), and
ERR_free_strings() were deprecated in openssl 1.1.0, and shouldn't be
called on newer versions. In some runtime library versions, the symbols
may not even exist in the library anymore, leading to errors like:

  ERROR:  could not load library "/usr/pgsql-18/lib/timescaledb-2.25.1.so":
    /usr/pgsql-18/lib/timescaledb-2.25.1.so: undefined symbol: SSL_library_init
---
 .unreleased/pr_9277 | 2 ++
 src/net/conn_ssl.c  | 6 ++++++
 2 files changed, 8 insertions(+)
 create mode 100644 .unreleased/pr_9277

diff --git a/.unreleased/pr_9277 b/.unreleased/pr_9277
new file mode 100644
index 00000000000..8f61e6091df
--- /dev/null
+++ b/.unreleased/pr_9277
@@ -0,0 +1,2 @@
+Fixes: #9277 Fix SSL-related build errors
+Thanks: @tureba for fixing SSL-related build errors
diff --git a/src/net/conn_ssl.c b/src/net/conn_ssl.c
index 97f849abc57..3f78c522037 100644
--- a/src/net/conn_ssl.c
+++ b/src/net/conn_ssl.c
@@ -267,14 +267,20 @@ extern void _conn_ssl_fini(void);
 void
 _conn_ssl_init(void)
 {
+#if (OPENSSL_VERSION_NUMBER < 0x1010000fL)
+	/* OpenSSL < 1.1.0 requires explicit initialization */
 	SSL_library_init();
 	/* Always returns 1 */
 	SSL_load_error_strings();
+#endif
 	ts_connection_register(CONNECTION_SSL, &ssl_ops);
 }
 
 void
 _conn_ssl_fini(void)
 {
+#if (OPENSSL_VERSION_NUMBER < 0x1010000fL)
+	/* OpenSSL < 1.1.0 requires explicit cleanup */
 	ERR_free_strings();
+#endif
 }
